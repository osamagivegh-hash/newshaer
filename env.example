# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://osamagivegh:<db_password>@alshaer.sqs9w7.mongodb.net/?appName=ALSHAER
SOURCE_MONGODB_URI=
BOOTSTRAP_OVERWRITE=false

# Admin Credentials (Required for first login)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@alshaerfamily.com
ADMIN_PASSWORD=admin123

# JWT Secret Key (Generate a strong random string)
JWT_SECRET=your-jwt-secret-key


# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: Set to use Cloudinary instead of local storage
USE_CLOUDINARY=true
# Optional: Cloudinary folder name (default: al-shaer-family)
CLOUDINARY_FOLDER=al-shaer-family

# Email Configuration (Optional - for contact form notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=<APP_SPECIFIC_SECRET>
EMAIL_FROM=noreply@alshaerfamily.com

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# News Feeds Configuration
NEWS_FETCH_CRON=*/2 * * * *
NEWS_MAX_ITEMS=50

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Frontend API Base URL
VITE_API_BASE_URL=http://localhost:5000

# Production Notes
# On Render, keep VITE_API_BASE_URL empty when frontend and backend are served from the same service.
# To import recovered content into the new cluster:
# npm run db:bootstrap
